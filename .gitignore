# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma migration tools and data dumps
prisma/extract_data.ts
prisma/import_data.ts
prisma/sqlite_data_dump.json
prisma/dev.db
prisma/dev.db-journal

# Local logs
*.log
build_output.txt
ts_errors_utf8.log

/src/generated/prisma
